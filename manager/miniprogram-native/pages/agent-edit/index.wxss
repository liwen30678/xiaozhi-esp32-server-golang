@import "../../app.wxss";

.field-input,
.picker-value {
  margin-bottom: 14rpx;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  margin-bottom: 8rpx;
}

.voice-row {
  margin: 4rpx 0 8rpx;
}

.muted-picker {
  color: #8a7664;
}

.kb-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ebdece;
}

.kb-info {
  flex: 1;
  min-width: 0;
}

.kb-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #3f3024;
}

.kb-meta {
  margin-top: 4rpx;
  color: #8a7664;
  font-size: 24rpx;
}

.save-btn {
  margin-top: 20rpx;
}
