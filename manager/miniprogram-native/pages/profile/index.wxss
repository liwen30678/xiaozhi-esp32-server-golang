@import "../../app.wxss";

.action-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.action-list button {
  flex: 1;
  min-width: 200rpx;
}

.profile-quick {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 238, 216, 0.18);
  border: 1rpx solid rgba(241, 212, 179, 0.36);
  color: #f3dfc8;
  font-size: 22rpx;
}

.profile-chip.role {
  color: #fde9d2;
}

.profile-line {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #ecdfcf;
}

.profile-line.no-border {
  border-bottom: none;
}

.profile-line .label {
  color: #8a7763;
  font-size: 22rpx;
}

.profile-line .value {
  margin-top: 4rpx;
  color: #3f3023;
  font-size: 26rpx;
  word-break: break-all;
}
