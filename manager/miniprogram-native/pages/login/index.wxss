@import "../../app.wxss";

.login-container {
  padding-top: 42rpx;
}

.login-hero {
  margin-bottom: 20rpx;
}

.hero-tag {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 227, 197, 0.38);
  background: rgba(255, 237, 214, 0.14);
  color: #f4dfc9;
  font-size: 20rpx;
  letter-spacing: 0.5rpx;
}

.form-card {
  padding-bottom: 28rpx;
}

.field-label {
  margin: 8rpx 0 8rpx;
  color: #6f5b47;
  font-size: 24rpx;
  font-weight: 600;
}

.field-input {
  margin-bottom: 14rpx;
}

.login-btn {
  margin-top: 8rpx;
}

.login-hint {
  margin-top: 8rpx;
  padding: 4rpx 8rpx;
  color: #8e7a67;
  font-size: 22rpx;
  line-height: 1.5;
}
