<view class="container">
  <view class="card header-card">
    <view>
      <view class="title">智能体设备</view>
      <view class="muted">共 {{list.length}} 台</view>
    </view>
    <button size="mini" class="btn-primary mini-btn" bindtap="openBind">绑定设备</button>
  </view>

  <view class="card" wx:if="{{!list.length && !loading}}">
    <view class="muted">暂无设备，点击右上角绑定</view>
  </view>

  <view class="card device-card" wx:for="{{list}}" wx:key="id">
    <view class="device-name">{{item.device_name || '未命名设备'}}</view>
    <view class="device-meta">设备码：{{item.device_code || '-'}}</view>
    <view class="device-meta">激活状态：{{item.activated ? '已激活' : '未激活'}}</view>
    <view class="device-meta">最后活跃：{{item.last_active_text}}</view>
    <view class="device-meta">创建时间：{{item.created_text}}</view>
    <picker mode="selector" range="{{roleOptionNames}}" value="{{item.role_picker_index}}" data-id="{{item.id}}" bindchange="onRoleChange">
      <view class="picker-value">角色：{{roleOptionNames[item.role_picker_index]}}</view>
    </picker>
    <view class="actions">
      <button size="mini" type="warn" data-id="{{item.id}}" bindtap="removeDevice">移除</button>
    </view>
  </view>

  <view class="muted" wx:if="{{loading}}">加载中...</view>

  <view wx:if="{{showBind}}" class="sheet-mask" catchtap="closeBind">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">绑定设备验证码</view>
      <input class="sheet-input" placeholder="请输入6位验证码" maxlength="6" value="{{bindCode}}" bindinput="onBindCodeInput" />
      <view class="sheet-actions">
        <button size="mini" bindtap="closeBind">取消</button>
        <button size="mini" class="btn-primary" loading="{{binding}}" bindtap="submitBind">绑定</button>
      </view>
    </view>
  </view>
</view>
