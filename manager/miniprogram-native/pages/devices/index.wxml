<view class="container">
  <view class="card header-card">
    <view class="title">我的设备</view>
    <view class="muted">共 {{list.length}} 台</view>
  </view>

  <view class="card" wx:if="{{!list.length && !loading}}">
    <view class="muted">暂无设备</view>
  </view>

  <view class="card device-card" wx:for="{{list}}" wx:key="id">
    <view class="device-name">{{item.device_name || '未命名设备'}}</view>
    <view class="device-meta">设备码：{{item.device_code || '-'}}</view>
    <view class="device-meta">关联智能体：{{item.agent_name || '-'}}</view>
    <view class="device-meta">激活状态：{{item.activated ? '已激活' : '未激活'}}</view>
    <view class="device-meta">最后活跃：{{item.last_active_text}}</view>
    <view class="device-meta">创建时间：{{item.created_text}}</view>
    <picker mode="selector" range="{{roleOptionNames}}" value="{{item.role_picker_index}}" data-id="{{item.id}}" bindchange="onRoleChange">
      <view class="picker-value">角色：{{roleOptionNames[item.role_picker_index]}}</view>
    </picker>
  </view>

  <view class="muted" wx:if="{{loading}}">加载中...</view>
</view>
